doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Conway's Game of Life
    script(type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@1.0.0-RC.8/bundles/datastar.js")
    style.
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html, body {
        height: 100%;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 18px;
        background: #111;
        color: #eee;
      }
      .main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem;
        gap: 1rem;
      }
      h1 {
        font-size: 1.5rem;
      }
      p {
        font-size: 0.85rem;
        color: #aaa;
      }
      .board {
        display: grid;
        grid-template-rows: repeat(#{boardSize}, 1fr);
        grid-template-columns: repeat(#{boardSize}, 1fr);
        width: min(90vw, 90vh);
        height: min(90vw, 90vh);
        border: 1px solid #333;
      }
      .tile {
        border-right: 1px solid #222;
        border-bottom: 1px solid #222;
      }
      .dead { background: #1a1a1a; }
      .red { background: #e74c3c; transition: background 0.3s ease; }
      .blue { background: #3498db; transition: background 0.3s ease; }
      .green { background: #2ecc71; transition: background 0.3s ease; }
      .orange { background: #e67e22; transition: background 0.3s ease; }
      .fuchsia { background: #e91e9c; transition: background 0.3s ease; }
      .purple { background: #9b59b6; transition: background 0.3s ease; }
  body
    main.main
      h1 Conway's Game of Life
      p Click on the board to add cells. The simulation runs automatically.
      div(data-init="@get('/sse')")
        div#board.board(data-on:pointerdown="@post('/tap?id=' + evt.target.dataset.id)")
          != boardHtml
